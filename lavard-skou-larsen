<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lavard Skou Larsen | The Music Agency</title>
    
    <!-- Tailwind CSS for Styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- React and ReactDOM CDNs -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    
    <!-- Babel for JSX Transpiling -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&family=Playfair+Display:italic,wght@400;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
        }
        .font-serif {
            font-family: 'Playfair Display', serif;
        }
        
        /* Custom scrollbar for a premium feel */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        ::-webkit-scrollbar-thumb {
            background: #aa2b53;
        }

        /* Animation keyframes */
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .animate-fade-in {
            animation: fadeIn 1s ease-out forwards;
        }

        /* Hero Text readability helper since black filter is removed */
        .hero-text-shadow {
            text-shadow: 0px 2px 10px rgba(0,0,0,0.3);
        }

        /* Logo white filter : turns everything white on dark backgrounds */
        .logo-white-filter {
            filter: brightness(0) invert(1);
        }

        /* Force social icons to be white and have proper stroke */
        .social-icon-white svg {
            stroke: #ffffff !important;
            color: #ffffff !important;
            transition: stroke 0.3s ease;
        }
        
        .social-icon-white:hover svg {
            stroke: #aa2b53 !important;
            color: #aa2b53 !important;
        }
    </style>
</head>
<body class="bg-white text-black selection:bg-[#aa2b53] selection:text-white overflow-x-hidden">
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;
        
        // Native SVG components to ensure 100% visibility
        const ChevronDown = () => (
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        );
        const Menu = () => (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        );
        const X = () => (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        );
        const Facebook = ({ size = 18 }) => (
            <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        );
        const Instagram = ({ size = 18 }) => (
            <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        );
        const Mail = ({ size = 18 }) => (
            <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        );
        const ArrowRight = ({ size = 16 }) => (
            <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        );

        const App = () => {
            const [currentPage, setCurrentPage] = useState('artists');
            const [isMenuOpen, setIsMenuOpen] = useState(false);
            const [scrolled, setScrolled] = useState(false);
            const dropdownTimer = useRef(null);
            const [activeDropdown, setActiveDropdown] = useState(null);

            useEffect(() => {
                const handleScroll = () => setScrolled(window.scrollY > 50);
                window.addEventListener('scroll', handleScroll);
                return () => window.removeEventListener('scroll', handleScroll);
            }, []);

            const handleMouseEnter = (label) => {
                if (dropdownTimer.current) clearTimeout(dropdownTimer.current);
                setActiveDropdown(label);
            };

            const handleMouseLeave = () => {
                dropdownTimer.current = setTimeout(() => {
                    setActiveDropdown(null);
                }, 600);
            };

            const NavLink = ({ label, onClick, active }) => (
                <button 
                    onClick={onClick}
                    className={`text-[11px] uppercase tracking-[0.3em] font-semibold transition-all hover:text-[#aa2b53] ${active ? 'text-[#aa2b53]' : (scrolled ? 'text-black' : 'text-white')}`}
                >
                    {label}
                </button>
            );

            const NavDropdown = ({ label, children }) => (
                <div 
                    className="relative group py-2"
                    onMouseEnter={() => handleMouseEnter(label)}
                    onMouseLeave={handleMouseLeave}
                >
                    <button className={`flex items-center gap-1 text-[11px] uppercase tracking-[0.3em] font-semibold hover:text-[#aa2b53] transition-all ${scrolled ? 'text-black' : 'text-white'}`}>
                        {label} <span className="inline-block ml-1"><ChevronDown /></span>
                    </button>
                    {activeDropdown === label && (
                        <div className="absolute left-0 mt-4 w-72 bg-white shadow-2xl border-t border-[#aa2b53] animate-fade-in z-[200]">
                            <div className="py-4">
                                {children}
                            </div>
                        </div>
                    )}
                </div>
            );

            const DropdownItem = ({ href, label, external }) => (
                <a 
                    href={href} 
                    target={external ? "_blank" : "_self"}
                    rel={external ? "noopener noreferrer" : ""}
                    className="block px-8 py-4 hover:bg-gray-50 transition-colors group"
                >
                    <div className="flex justify-between items-center">
                        <span className="text-[10px] uppercase tracking-widest font-bold text-black group-hover:text-[#aa2b53] transition-colors leading-tight">{label}</span>
                    </div>
                </a>
            );

            return (
                <div className="min-h-screen flex flex-col">
                    <nav className={`fixed top-0 w-full z-[100] transition-all duration-700 ${scrolled ? 'bg-white shadow-sm border-b py-4' : 'bg-transparent py-8 text-white'}`}>
                        <div className="max-w-[1600px] mx-auto px-8">
                            <div className="flex items-center justify-between h-20 md:h-24">
                                <div className="hidden lg:flex flex-1 items-center gap-10">
                                    <NavLink label="Home" onClick={() => window.location.href = 'https://cfipc.github.io/themusicagency.eu/'} />
                                    <NavDropdown label="Festivals">
                                        <DropdownItem href="https://masterclass-volodos.com" label="Arcadi Volodos - Masterclass" external />
                                        <DropdownItem href="https://cfipc.com" label="César Franck International Piano Competition" external />
                                        <DropdownItem href="https://imfparis.fr" label="International Music Festival Paris" external />
                                        <DropdownItem href="https://cfipc.com" label="César Franck Young Talents & Orchestra" external />
                                    </NavDropdown>
                                    <NavDropdown label="Artists">
                                        <DropdownItem href="https://cfipc.github.io/themusicagency.eu/salzburg-chamber-soloists" label="Salzburg Chamber Soloists" />
                                        <DropdownItem href="https://cfipc.github.io/themusicagency.eu/jean-claude-vanden-eynden" label="Jean-Claude Vanden Eynden" />
                                        <DropdownItem href="https://cfipc.github.io/themusicagency.eu/philippe-raskin" label="Philippe Raskin" />
                                        <DropdownItem href="https://cfipc.github.io/themusicagency.eu/lavard-skou-larsen" label="Lavard Skou Larsen" />
                                    </NavDropdown>
                                </div>
                                <div className="flex flex-col items-center cursor-pointer px-6 md:px-12 group shrink-0" onClick={() => window.location.href = 'https://cfipc.github.io/themusicagency.eu/'}>
                                    <img 
                                        src="logo.png" 
                                        alt="TMA" 
                                        className={`h-28 md:h-40 mb-1 object-contain transition-all duration-700 ${!scrolled ? 'logo-white-filter' : ''}`} 
                                        onError={(e) => { e.target.style.display = 'none'; e.target.nextSibling.style.display = 'flex'; }}
                                    />
                                    <div className="hidden flex-col items-center">
                                        <span className={`text-2xl md:text-3xl font-black tracking-[0.3em] uppercase leading-none group-hover:text-[#aa2b53] ${scrolled ? 'text-black' : 'text-white'}`}>TMA</span>
                                        <span className={`text-[8px] tracking-[0.5em] uppercase font-bold opacity-60 ${scrolled ? 'text-black' : 'text-white'}`}>The Music Agency</span>
                                    </div>
                                </div>
                                <div className="hidden lg:flex flex-1 justify-end items-center gap-10">
                                    <NavLink label="News" onClick={() => window.location.href = 'https://cfipc.github.io/themusicagency.eu/news'} />
                                    <NavLink label="Contact" onClick={() => window.location.href = 'https://cfipc.github.io/themusicagency.eu/contact'} />
                                </div>
                                <button className={`lg:hidden p-2 ${scrolled ? 'text-black' : 'text-white'}`} onClick={() => setIsMenuOpen(true)}>
                                    <Menu />
                                </button>
                            </div>
                        </div>
                    </nav>

                    {isMenuOpen && (
                        <div className="fixed inset-0 bg-white z-[200] p-8 flex flex-col animate-fade-in overflow-y-auto">
                            <div className="flex justify-between items-center mb-16">
                                <span className="text-2xl font-black tracking-widest uppercase">TMA</span>
                                <button onClick={() => setIsMenuOpen(false)} className="p-2 bg-black text-white rounded-full"><X /></button>
                            </div>
                            <div className="flex flex-col gap-8">
                                <button onClick={() => window.location.href = 'https://cfipc.github.io/themusicagency.eu/'} className="text-4xl font-black uppercase tracking-tighter text-left">Home</button>
                                <div className="space-y-4">
                                    <p className="text-[#aa2b53] font-black uppercase tracking-widest text-xs">Festivals</p>
                                    <div className="flex flex-col gap-4 pl-4 border-l border-gray-100">
                                        <a href="https://masterclass-volodos.com" target="_blank" className="text-xl font-light">Arcadi Volodos - Masterclass</a>
                                        <a href="https://cfipc.com" target="_blank" className="text-xl font-light">César Franck IPC</a>
                                    </div>
                                </div>
                                <button onClick={() => window.location.href = 'https://cfipc.github.io/themusicagency.eu/news'} className="text-4xl font-black uppercase tracking-tighter text-left">News</button>
                                <button onClick={() => window.location.href = 'https://cfipc.github.io/themusicagency.eu/contact'} className="text-4xl font-black uppercase tracking-tighter text-left">Contact</button>
                            </div>
                        </div>
                    )}

                    <div className="animate-fade-in">
                        {/* Header Section */}
                        <section className="relative h-[60vh] bg-black overflow-hidden">
                            <img 
                                src="lavard.png" 
                                alt="Lavard Skou Larsen" 
                                className="w-full h-full object-cover opacity-60"
                                onError={(e) => { e.target.src = "https://images.unsplash.com/photo-1520529611404-6153c5163979?auto=format&fit=crop&q=80&w=1600"; }}
                            />
                            <div className="absolute inset-0 flex flex-col justify-center items-center text-center px-6">
                                <span className="text-[#aa2b53] font-bold tracking-[0.6em] uppercase text-xs mb-4 hero-text-shadow">Artists</span>
                                <h1 className="text-white text-4xl md:text-7xl font-black uppercase tracking-tighter mb-4 max-w-5xl hero-text-shadow">Lavard <br/>SKOU LARSEN</h1>
                                <p className="text-[#aa2b53] font-bold tracking-[0.4em] uppercase text-xs hero-text-shadow">Conductor</p>
                            </div>
                        </section>

                        {/* Biography Section */}
                        <section className="py-20 md:py-32 px-6 bg-white">
                            <div className="max-w-4xl mx-auto">
                                <div className="mb-12">
                                    <span className="text-[#aa2b53] font-black uppercase tracking-[0.3em] text-xs mb-4 block">Biography</span>
                                    <div className="h-[2px] w-12 bg-[#aa2b53]"></div>
                                </div>
                                
                                <div className="space-y-8 text-gray-700 leading-relaxed text-lg font-serif text-justify">
                                    <p className="first-letter:text-5xl first-letter:font-black first-letter:text-[#aa2b53] first-letter:mr-3 first-letter:float-left">
                                        Conductor Lavard Skou Larsen’s passionate music-making inspires audiences of all ages. Serving as Music Director of both, the Deutsche Kammerakademie Neuss by Duesseldorf from 2004 until 2017, and the Georgische Kammerorchester in Ingoldstadt / Germany from 2012 until 2014, the impact of his musical leadership was felt after his first concerts and continues with his imaginative programs and record audience attendance.
                                    </p>
                                    <p>
                                        His commitment to these posts accounts for the major portion of his agenda, while increasingly in demand as guest conductor in Brazil, Germany, Austria, Switzerland, Russia, France and in the USA. He has conducted symphony and chamber orchestras with equal success, such as the Mozarteum Salzburg, the Dresden Philharmonie, Dusseldorf Symphony, Rheinische Philharmonie, Orchestre National de Lorraine, Orchestre des Pays de Savoie, Orchestre de Chambre de Genève, Berne Symphony Orchestra, Orquestra Sinfonica Brasileira de Rio de Janeiro, Orquestra Sinfonica de Porto Alegre, Orquestra National do Porto, Orquestra Ciudad de Almeria, Mikkeli City Orchestra, Erasmus Chamber Orchestra, European Union Chamber Orchestra, Armenia Philharmonic Orchestra, and the Texas Music Festival for young professionals.
                                    </p>
                                    <p>
                                        The most recent seasons included re-invitations with the Berne Symphony, Switzerland, Erasmus Chamber Orchestra, Holland, Orchestra de Chambre de Genève, the Texas Music Festival and the regular opening concerts with the Salzburg Chamber Soloists at the International Summer Academy, Mozarteum in collaboration with the Salzburg Festival. Upcoming performances will be with the Basel Sinfonietta, Switzerland, Orquestra Sinfonica de Porto Alegre, Brazil, Vogtland Philharmonie Reichenau, Germany and the Leopoldinum Chamber Orchestra, Poland.
                                    </p>
                                    <p>
                                        Lavard Skou Larsen, Music Director of three orchestras, has expanded with his leadership its diversified programs and outreach projects, most notably with the Salzburg Chamber Orchestra’s over fifty successful concerts in the USA. Appearing at the Kennedy Center in Washington, DC, the Metropolitan Museum, New York, Cerritos Center in Los Angeles, Wenz Concert Hall by Chicago, and in major concert halls in St. Louis, Denver, Salt Lake City, San Diego, Charlotte, Houston, and Palm Beach, the ensemble was enthusiastically received by the audience and critics alike. Lavard Skou Larsen and the Salzburg Chamber Soloists inspired with their outreach projects for children and young audiences throughout the United States.
                                    </p>
                                    <p>
                                        As Professor in violin at the prominent Salzburg Mozarteum, Lavard Skou Larsen cultivates the next generation of superb musicians in his studio since 2002. His students came to be soloists and members of top orchestras.
                                    </p>
                                    <p>
                                        His conducting skills developed naturally through the early mentoring by his father Gunnar, and were molded by his inspiration of his role model, maestro Sergio Celibidache, which at age fifteen resulted in the first prize of Austria’s Young Musicians Competition. Already at age 23, he was offered to take charge of the European Union Chamber Orchestra as artistic director and leader.
                                    </p>
                                </div>

                                <div className="mt-16 pt-12 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-8">
                                    <a 
                                        href="http://www.salcsol.com/en/artistic-director" 
                                        target="_blank" 
                                        rel="noopener noreferrer"
                                        className="px-10 py-5 bg-black text-white font-bold uppercase tracking-[0.2em] text-xs hover:bg-[#aa2b53] transition-all shadow-xl"
                                    >
                                        More Info
                                    </a>
                                    <button 
                                        onClick={() => window.location.href = 'https://cfipc.github.io/themusicagency.eu/contact'}
                                        className="group flex items-center gap-4 text-[11px] font-black uppercase tracking-[0.2em] border-b-2 border-black pb-2 hover:text-[#aa2b53] hover:border-[#aa2b53] transition-all"
                                    >
                                        Booking Inquiries <ArrowRight />
                                    </button>
                                </div>
                            </div>
                        </section>
                    </div>

                    <footer className="bg-black text-white py-16 md:py-24 px-8 mt-auto">
                        <div className="max-w-[1600px] mx-auto flex flex-col items-center">
                            <div className="mb-12 flex flex-col items-center group cursor-pointer" onClick={() => window.location.href = 'https://cfipc.github.io/themusicagency.eu/'}>
                                <img 
                                    src="logo.png" 
                                    alt="The Music Agency" 
                                    className="h-32 md:h-48 mb-4 object-contain logo-white-filter" 
                                    onError={(e) => { e.target.style.display = 'none'; e.target.nextSibling.style.display = 'flex'; }}
                                />
                                <div className="hidden flex-col items-center">
                                    <span className="text-3xl md:text-4xl font-black tracking-[0.3em] uppercase leading-none">TMA</span>
                                    <div className="h-[2px] w-8 bg-[#aa2b53] my-2"></div>
                                    <span className="text-[10px] tracking-[0.5em] uppercase font-bold opacity-60">The Music Agency</span>
                                </div>
                            </div>
                            <div className="flex gap-6 md:gap-8 mb-12">
                                <a href="https://www.facebook.com/themusicagency.eu" target="_blank" className="social-icon-white w-12 h-12 md:w-14 md:h-14 rounded-full border border-white flex items-center justify-center text-white hover:border-[#aa2b53] transition-all group/social">
                                    <Facebook size={22} />
                                </a>
                                <a href="https://www.instagram.com/the.music.agency" target="_blank" className="social-icon-white w-12 h-12 md:w-14 md:h-14 rounded-full border border-white flex items-center justify-center text-white hover:border-[#aa2b53] transition-all group/social">
                                    <Instagram size={22} />
                                </a>
                                <a href="mailto:office@themusicagency.eu" className="social-icon-white w-12 h-12 md:w-14 md:h-14 rounded-full border border-white flex items-center justify-center text-white hover:border-[#aa2b53] transition-all group/social">
                                    <Mail size={22} />
                                </a>
                            </div>
                            <div className="pt-12 border-t border-white/5 w-full text-center">
                                <p className="text-[10px] uppercase tracking-[0.4em] text-gray-500">© 2026 The Music Agency. Designed for Excellence.</p>
                            </div>
                        </div>
                    </footer>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
